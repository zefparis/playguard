# ── PlayGuard backend (backend/.env) ──────────────────────────────────────────
# Set to 21 (not 18) to compensate for AWS Rekognition over-aging bias on children
# VERIFY_AGE verdict triggers when AgeRange.Low < 25 and face is not already MINOR
PG_AGE_THRESHOLD=21
